# Runtime
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/lpu_os_lab

# Auth
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173

# Mail (OTP)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_SERVICE=gmail
# Optional custom SMTP (use instead of EMAIL_SERVICE when needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# AI provider keys (configure at least one)
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# AI provider selection and fallback
AI_PROVIDER=gemini
AI_FALLBACK=true
AI_FORCE_LOCAL=false
AI_LOCAL_FALLBACK=true
AI_LOCAL_FALLBACK_GENERATION=false

# Optional provider-specific model/base URL overrides
GEMINI_MODEL=
OPENAI_MODEL=gpt-4o-mini
XAI_MODEL=grok-4.20-reasoning
XAI_BASE_URL=https://api.x.ai/v1
